# ============================================================
# .env.example — AI Router Pipeline
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# =============== DATABASE (Required) =======================
# NeonDB, Supabase, or any PostgreSQL with pgvector enabled
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============== AI PROVIDER KEYS ==========================
# At least GEMINI_API_KEY is required (used as the primary router)
GEMINI_API_KEY=your-google-ai-studio-key-here

# Optional — adds more fallback options
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-key-here
NVIDIA_API_KEY=
# Optional — additional providers
XAI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
COHERE_API_KEY=

# =============== SECURITY ==================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=replace-with-a-long-random-string

# =============== FEATURE 13: Operator System Prompt ========
# Applied globally to every request. Leave blank for default behavior.
# Example: "You are an assistant specialized in mining and ore detection."
OPERATOR_SYSTEM_PROMPT=

# =============== OPTIONAL TUNING ===========================
# RATE_LIMIT_MAX_RPM=30
# RATE_LIMIT_WINDOW_SECONDS=60
# MEMORY_MAX_FACTS_PER_TURN=5
# GOOGLE_MAX_OUTPUT_TOKENS=8192
# ANTHROPIC_MAX_OUTPUT_TOKENS=4096


#Un comment after u installed all the models
#TRANSFORMERS_OFFLINE=1
#HF_HUB_OFFLINE=1
#OMP_NUM_THREADS=1
#MKL_NUM_THREADS=1
#TOKENIZERS_PARALLELISM=false
